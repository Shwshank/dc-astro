{
  "hosting": {
    "public": "dist",
    "cleanUrls": true,
    "trailingSlash": false,

    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".github/**",
      "**/.git/**",
      "**/node_modules/**",
      "**/.DS_Store"
    ],

    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|png|svg|webp|gif)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=604800"
          }
        ]
      }
    ],

    "redirects": [
      {
        "source": "/index.html",
        "destination": "/",
        "type": 301
      }
    ]
  },

  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}